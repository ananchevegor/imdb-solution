{% extends 'base.html.twig' %}

{% block title %}IMDb Solution{% endblock %}

{% block body %}
    <main style="max-width: 860px; margin: 3rem auto; padding: 0 1rem; font-family: sans-serif;">
        <h1 style="margin-bottom: 0.75rem;">IMDb Solution</h1>
        <p style="margin-bottom: 1rem;">
            The project now supports server-rendered pages with Twig in addition to API endpoints.
        </p>

        <section style="margin-bottom: 1.5rem;">
            <h2 style="margin-bottom: 0.5rem;">What is ready</h2>
            <ul>
                <li>the home page is rendered with Twig;</li>
                <li>the custom <code>greet</code> Twig filter is available;</li>
                <li>the existing API routes stay unchanged.</li>
            </ul>
        </section>

        <section>
            <h2 style="margin-bottom: 0.5rem;">Filter example</h2>
            <p>{{ 'Egor'|greet }}</p>
        </section>
    </main>
{% endblock %}
