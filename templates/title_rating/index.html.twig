{% extends 'base.html.twig' %}

{% block title %}Title Ratings{% endblock %}

{% block body %}
    <main style="max-width: 1100px; margin: 3rem auto; padding: 0 1rem; font-family: sans-serif;">
        <h1 style="margin-bottom: 0.5rem;">IMDb Title Ratings</h1>
        <p style="margin-bottom: 1.5rem;">
            Total records in the table: <strong>{{ total }}</strong>
        </p>

        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="text-align: left; border-bottom: 1px solid #ccc; padding: 0.75rem;">tconst</th>
                    <th style="text-align: left; border-bottom: 1px solid #ccc; padding: 0.75rem;">Average rating</th>
                    <th style="text-align: left; border-bottom: 1px solid #ccc; padding: 0.75rem;">Votes</th>
                </tr>
            </thead>
            <tbody>
                {% for rating in ratings %}
                    <tr>
                        <td style="border-bottom: 1px solid #eee; padding: 0.75rem;">{{ rating.tconst }}</td>
                        <td style="border-bottom: 1px solid #eee; padding: 0.75rem;">{{ rating.averageRating }}</td>
                        <td style="border-bottom: 1px solid #eee; padding: 0.75rem;">{{ rating.numVotes }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" style="padding: 1rem;">No data found yet.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </main>
{% endblock %}
