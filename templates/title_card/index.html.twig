{% extends 'base.html.twig' %}

{% set pageTitle = (titleBasic and titleBasic.primaryTitle) ? titleBasic.primaryTitle : (titleAkas.title|default('Title card')) %}
{% set directorIds = (titleCrew and titleCrew.directors) ? titleCrew.directors|split(',') : [] %}
{% set writerIds = (titleCrew and titleCrew.writers) ? titleCrew.writers|split(',') : [] %}
{% set originalTitle = (titleBasic and titleBasic.originalTitle) ? titleBasic.originalTitle : null %}
{% set primaryTitle = (titleBasic and titleBasic.primaryTitle) ? titleBasic.primaryTitle : null %}
{% set titleType = (titleBasic and titleBasic.titleType) ? titleBasic.titleType : null %}
{% set startYear = (titleBasic and titleBasic.startYear) ? titleBasic.startYear : null %}
{% set endYear = (titleBasic and titleBasic.endYear) ? titleBasic.endYear : null %}
{% set runtimeMinutes = (titleBasic and titleBasic.runtimeMinutes) ? titleBasic.runtimeMinutes : null %}
{% set genres = (titleBasic and titleBasic.genres) ? titleBasic.genres : null %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block stylesheets %}
    <style>
        body {
            margin: 0;
            background: #fff;
            color: #000;
            font-family: Georgia, serif;
        }

        main {
            max-width: 980px;
            margin: 0 auto;
            padding: 32px 20px 48px;
            text-align: center;
        }

        nav,
        header,
        section {
            margin-bottom: 28px;
        }

        nav {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        header,
        section {
            padding: 24px 20px;
        }

        h1,
        h2,
        h3 {
            margin-bottom: 12px;
        }

        p,
        li {
            line-height: 1.6;
        }

        ul {
            padding: 0;
            margin: 0 auto;
            max-width: 760px;
            list-style: none;
        }

        li {
            margin: 0;
            padding: 12px 16px;
        }

        article {
            width: 100%;
            max-width: 760px;
            margin: 0 auto 20px;
            padding: 0;
            text-align: left;
        }

        article h3 {
            margin: 0;
            padding: 14px 18px;
            text-align: center;
        }

        article p {
            margin: 0;
            padding: 12px 18px;
        }

        table {
            width: 100%;
            margin: 0 auto;
            border-collapse: separate;
            border-spacing: 0;
        }

        th,
        td {
            padding: 10px;
            text-align: center;
        }

        hr {
            margin: 24px auto;
            border: 0;
            max-width: 320px;
        }

        a {
            color: #000;
        }

        .meta-line {
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 12px;
            align-items: center;
        }

        .meta-line strong {
            text-align: left;
        }

        .meta-line span {
            text-align: right;
        }

        .stack {
            display: grid;
            gap: 18px;
        }

        .section-note {
            max-width: 760px;
            margin: 0 auto;
        }

        @media (max-width: 720px) {
            main {
                padding: 24px 14px 36px;
            }

            .meta-line {
                grid-template-columns: 1fr;
                gap: 6px;
            }

            .meta-line strong,
            .meta-line span {
                text-align: center;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <main>
        <nav>
            <a href="{{ path('index.php') }}">Home</a>
            |
            <a href="{{ path('title_basics_all.php') }}">All titles</a>
            |
            <a href="{{ path('title_rating_page') }}">Ratings</a>
        </nav>

        <hr>

        <header>
            <h1>{{ pageTitle }}</h1>

            {% if originalTitle and originalTitle != pageTitle %}
                <p>Original title: {{ originalTitle }}</p>
            {% elseif titleAkas.title and titleAkas.title != pageTitle %}
                <p>Alternative title: {{ titleAkas.title }}</p>
            {% endif %}

            <p>ID: {{ tconst }}</p>
        </header>

        <hr>

        <section>
            <h2>Quick facts</h2>
            <ul>
                <li class="meta-line"><strong>Primary title</strong><span>{{ primaryTitle ? primaryTitle : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Original title</strong><span>{{ originalTitle ? originalTitle : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Alternative title</strong><span>{{ titleAkas.title ? titleAkas.title : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Type</strong><span>{{ titleType ? titleType : 'Not specified' }}</span></li>
                <li class="meta-line">
                    <strong>Years</strong>
                    <span>
                        {% if startYear %}
                            {{ startYear }}{% if endYear %} - {{ endYear }}{% endif %}
                        {% else %}
                            Not specified
                        {% endif %}
                    </span>
                </li>
                <li class="meta-line"><strong>Runtime</strong><span>{{ runtimeMinutes ? runtimeMinutes ~ ' min' : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Genres</strong><span>{{ genres ? genres : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Region</strong><span>{{ titleAkas.region ? titleAkas.region : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Language</strong><span>{{ titleAkas.language ? titleAkas.language : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Types</strong><span>{{ titleAkas.types ? titleAkas.types : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Attributes</strong><span>{{ titleAkas.attributes ? titleAkas.attributes : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Original flag</strong><span>{{ titleAkas.isOriginalTitle ? 'Yes' : 'No' }}</span></li>
                <li class="meta-line"><strong>Ordering</strong><span>{{ titleAkas.ordering is not null ? titleAkas.ordering : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Average rating</strong><span>{{ averageRating is not null ? averageRating : 'Not specified' }}</span></li>
                <li class="meta-line"><strong>Votes</strong><span>{{ numVotes is not null ? numVotes : 'Not specified' }}</span></li>
            </ul>
        </section>

        <hr>

        <section>
            <h2>Crew</h2>

            {% if nameBasics|default([]) is not empty %}
                <div class="stack">
                {% for person in nameBasics|default([]) %}
                    {% if person %}
                        <article>
                            <h3>{{ person.primaryName ? person.primaryName : (person.nconst ? person.nconst : 'Unknown crew member') }}</h3>
                            <p>ID: {{ person.nconst ? person.nconst : 'Not specified' }}</p>
                            <p>Profession: {{ person.primaryProfession ? person.primaryProfession : 'Not specified' }}</p>
                            <p>
                                Years:
                                {% if person.birthYear %}
                                    {{ person.birthYear }}
                                {% else %}
                                    Unknown birth year
                                {% endif %}
                                {% if person.deathYear %}
                                    - {{ person.deathYear }}
                                {% endif %}
                            </p>
                            <p>
                                Role:
                                {% if person.nconst and person.nconst in directorIds %}
                                    Director
                                {% endif %}
                                {% if person.nconst and person.nconst in writerIds %}
                                    {% if person.nconst and person.nconst in directorIds %} / {% endif %}Writer
                                {% endif %}
                                {% if not (person.nconst and (person.nconst in directorIds or person.nconst in writerIds)) %}
                                    Not specified
                                {% endif %}
                            </p>
                        </article>
                    {% else %}
                        <article>
                            <h3>Unknown crew member</h3>
                            <p>Related person data is missing in `imdb_name_basics`.</p>
                        </article>
                    {% endif %}
                {% endfor %}
                </div>
            {% else %}
                <p class="section-note">Crew members were not found for this title.</p>
            {% endif %}
        </section>

        <section>
            <h2>Principals</h2>

            {% if tPNames %}
                <p class="section-note">
                    Principal name: {{ tPNames.primaryName ? tPNames.primaryName : (tPNames.nconst ? tPNames.nconst : 'Not specified') }}
                </p>
            {% endif %}

            {% if titlePrincipals|default([]) is not empty %}
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Person ID</th>
                            <th>Category</th>
                            <th>Job</th>
                            <th>Characters</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for principal in titlePrincipals %}
                            <tr>
                                <td>{{ principal.ordering }}</td>
                                <td>{{ principal.nconst ? principal.nconst : 'Not specified' }}</td>
                                <td>{{ principal.category ? principal.category : 'Not specified' }}</td>
                                <td>{{ principal.job ? principal.job : 'Not specified' }}</td>
                                <td>
                                    {{ principal.characters
                                        ? principal.characters|replace({'["': '', '"]': '', '","': ', '})
                                        : 'Not specified'
                                    }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p>No principal cast or crew rows were returned for this title.</p>
            {% endif %}
        </section>

        <hr>

        <section>
            <h2>Known for titles</h2>

            {% if knftBasics|default([]) is not empty %}
                <div class="stack">
                {% for relatedGroup in knftBasics|default([]) %}
                    {% set relatedTitle = relatedGroup|first %}
                    {% if relatedTitle %}
                        <article>
                            <h3>{{ relatedTitle.primaryTitle ? relatedTitle.primaryTitle : (relatedTitle.originalTitle ? relatedTitle.originalTitle : 'Untitled') }}</h3>
                            <p>ID: {{ relatedTitle.tconst }}</p>
                            <p>Type: {{ relatedTitle.titleType ? relatedTitle.titleType : 'Unknown type' }}</p>
                            <p>
                                Years:
                                {% if relatedTitle.startYear %}
                                    {{ relatedTitle.startYear }}{% if relatedTitle.endYear %} - {{ relatedTitle.endYear }}{% endif %}
                                {% else %}
                                    Not specified
                                {% endif %}
                            </p>
                            <p>Genres: {{ relatedTitle.genres ? relatedTitle.genres : 'Not specified' }}</p>
                            <p><a href="/card/{{ relatedTitle.tconst }}">Open related card</a></p>
                        </article>
                    {% endif %}
                {% endfor %}
                </div>
            {% else %}
                <p class="section-note">Related titles were not found for the current creative team.</p>
            {% endif %}
        </section>
    </main>
{% endblock %}
